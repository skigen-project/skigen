// Skigen/TypeAliases — Convenience type aliases for common scalar types.
//
// Provides shorthand names like StandardScalerD (double), StandardScalerF
// (float) analogous to Eigen's MatrixXd/MatrixXf pattern.
//
// Usage:
//   #include <Skigen/Dense>       // includes this automatically
//   Skigen::StandardScalerD scaler;
//   Skigen::RidgeD ridge(1.0);

